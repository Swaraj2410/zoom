# Backend environment variables

# Port where the backend server will listen
PORT=8000

# Frontend URL allowed by CORS
FRONTEND_URL=http://localhost:3000

# PostgreSQL connection settings
# For Render, use your Render Postgres internal connection details
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_postgres_password
DB_NAME=zoom_video_app

# Node Environment
NODE_ENV=development

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000      # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100      # Max requests per window

# JWT Configuration (auto-configured via RSA keys)
# Access token expiration: 1 hour (configured in jwt.js)
# Refresh token expiration: 30 days (configured in jwt.js)
RSA_KEY_PATH=./keys

# HTTPS/TLS Configuration
ENABLE_HTTPS=false
SSL_CERT_PATH=./certs/certificate.crt
SSL_KEY_PATH=./certs/private.key

# Logging
LOG_LEVEL=debug

# Add other sensitive configuration values here as needed
# NEVER commit actual keys, passwords, or certificates to version control

